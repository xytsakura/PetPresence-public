# PetPresence public example configuration.
# The default creator pipeline runs with pet_demo and the local synthetic provider.
# It does not require paid APIs, media uploads, camera streams, or observer services.
PETPRESENCE_PET_ID=pet_demo

# Optional video-generation provider adapter configuration.
# The local example provider does not require these values.
PETPRESENCE_VIDEO_PROVIDER=example-local-synthetic
PETPRESENCE_VIDEO_API_KEY=
PETPRESENCE_VIDEO_API_BASE=

# Optional model configuration for experimental observer features.
# These are not used by the default creator pipeline.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional local service URLs for experimental realtime observer flows.
EVENT_SERVER_URL=http://127.0.0.1:4317
OBSERVER_URL=http://127.0.0.1:3002

# Optional local tools.
FFMPEG_PATH=
PETPRESENCE_PYTHON=
